[alias]
    tree = log --oneline --decorate --graph --all
    tree-a = log --graph --pretty=format:'%Cred%h%Creset -%C(auto)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --all
	  ch = !git checkout $(git branch --all | fzf | tr -d \"[[:space:]]\")

[core]
    pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true  # use n and N to move between diff sections
    dark = true      # or light = true, or omit for auto-detection
    line-numbers = true

[merge]
    conflictStyle = zdiff3
